        HR["HR"] --> RES["Resources<br/><i>Person / Machine</i>"]
        RES --> PROJ["Jobs<br/>[Projects]"]
        PROJ --> SVC["Services<br/><i>(Premium)</i>"]
        PROJ --> SUB["Subscription<br/>Billing"]
    end

    ITEM --> APR

